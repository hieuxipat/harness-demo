{
  "mcpServers": {
    "shopify-dev-mcp": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@shopify/dev-mcp@latest"],
      "env": {}
    },
    "codegraph-frontend": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@colbymchenry/codegraph@latest", "serve", "--mcp", "--path", "frontend"]
    },
    "codegraph-backend": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@colbymchenry/codegraph@latest", "serve", "--mcp", "--path", "backend"]
    },
    "codegraph-storefront": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@colbymchenry/codegraph@latest", "serve", "--mcp", "--path", "storefront"]
    }
  }
}
