{
  "name": "fullstack",
  "description": "React + Node.js fullstack monorepo",
  "type": "project",
  "variables": [
    {
      "name": "project_name",
      "prompt": "Project name?",
      "default": "my-fullstack-app",
      "type": "input",
      "required": true
    },
    {
      "name": "description",
      "prompt": "Description?",
      "default": "",
      "type": "input",
      "required": false
    },
    {
      "name": "client_port",
      "prompt": "Client dev port?",
      "default": "3000",
      "type": "input",
      "required": false
    },
    {
      "name": "server_port",
      "prompt": "Server port?",
      "default": "4000",
      "type": "input",
      "required": false
    },
    {
      "name": "include_e2e",
      "prompt": "Include Playwright E2E?",
      "default": true,
      "type": "confirm"
    }
  ],
  "conditionals": {
    "client/e2e": "include_e2e"
  }
}
