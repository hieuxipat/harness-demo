{
  "name": "shopify-app",
  "description": "Shopify embedded app with React (Polaris) + Node.js backend",
  "type": "project",
  "variables": [
    {
      "name": "project_name",
      "prompt": "App name?",
      "default": "my-shopify-app",
      "type": "input",
      "required": true
    },
    {
      "name": "description",
      "prompt": "Description?",
      "default": "",
      "type": "input",
      "required": false
    },
    {
      "name": "shopify_api_key",
      "prompt": "Shopify API key?",
      "default": "",
      "type": "input",
      "required": false
    },
    {
      "name": "include_extensions",
      "prompt": "Include app extensions?",
      "default": false,
      "type": "confirm"
    },
    {
      "name": "include_billing",
      "prompt": "Include billing/subscriptions?",
      "default": true,
      "type": "confirm"
    }
  ],
  "conditionals": {
    "extensions": "include_extensions"
  }
}
